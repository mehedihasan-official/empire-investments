# ──────────────────────────────────────────────────────────────────────────────
# FIREBASE CONFIGURATION
# Get these from: https://console.firebase.google.com
# → Your Project → Project Settings → Your Apps → Web App
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id


# ──────────────────────────────────────────────────────────────────────────────
# FIREBASE ADMIN SDK (For server-side authentication)
# Get these from: Firebase Console → Project Settings → Service Accounts
# Download the private key JSON and copy the values
# ──────────────────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_service_account_email@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ──────────────────────────────────────────────────────────────────────────────
# MONGODB CONFIGURATION
# Get your MongoDB connection string from MongoDB Atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
# ──────────────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/empire_investments?retryWrites=true&w=majority

# ──────────────────────────────────────────────────────────────────────────────
# FACEBOOK PIXEL (Optional - for tracking)
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FB_PIXEL_ID=your_facebook_pixel_id
FB_PIXEL_ID=your_facebook_pixel_id
FB_ACCESS_TOKEN=your_facebook_access_token
